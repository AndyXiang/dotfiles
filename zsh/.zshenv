# environment variables

# default editor
export EDITOR=nvim

# zsh configs directory
export ZDOTDIR="$HOME/.config/zsh"

# proxy
export http_proxy=http://127.0.0.1:7890
export https_proxy=http://127.0.0.1:7890
export HTTP_PROXY=http://127.0.0.1:7890
export HTTPS_PROXY=http://127.0.0.1:7890

# local bin
export PATH="$HOME/.local/bin:$PATH"
